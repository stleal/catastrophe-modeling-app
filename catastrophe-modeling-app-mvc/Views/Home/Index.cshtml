@{
    ViewData["Title"] = "Home Page";
}

<div>
    <h1>Welcome</h1>
    <p>Please use the upload feature to import a HURDAT2 file for processing.</p>
    <form>
        <table>
            <tr>
                <td><label for="fileUpload">Upload HURDAT2 File:</label></td>
            </tr>
            <tr>
                <td><input type="file" id="fileUpload" name="fileUpload"/></td>
            </tr>
            <tr>
                <td><input type="submit" id="submitBtn"/></td>
            </tr>
        </table>
    </form>

    <table>
        <tr>Name of Storm</tr>
        <tr>Date of Landfall</tr>
        <tr>Maximum Windspeed Achieved</tr>
    </table>

</div>