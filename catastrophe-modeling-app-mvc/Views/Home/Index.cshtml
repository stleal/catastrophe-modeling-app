@using System.Text.Json
@model IEnumerable<StormInfo>

@{
    ViewData["Title"] = "Home Page";
    var storms = (Model ?? System.Linq.Enumerable.Empty<StormInfo>()).ToList();
    var stormInfoDisplay = storms.Any() ? "block" : "none";
}

<div id="wrapper" style="width: 75%; margin: auto;">
    <div class="card text-white mb-3" style="max-width: 80rem; background-color: #1c3d6e; padding: 1rem;">
    <div class="card-header">HURDAT2</div>
        <div class="card-body">
            <h4 class="card-title">Upload</h4>
            <p class="card-text">Please use the upload feature to import a HURDAT2 file for processing.</p>
            <form>
                <table>
                    <tr>
                        <td><input type="file" id="fileUpload" name="fileUpload"/></td>
                    </tr>
                </table>
                <br/>
                <input type="submit" id="submitBtn"/>
            </form>
        </div>
    </div>

    <div id="stormInfoSection" style="max-width: 80rem; display:@stormInfoDisplay">
        <h2>Storm Info</h2><br/>
        <div class="storm-table-controls">
            <label for="pageSizeSelect">Records per page:</label>
            <select id="pageSizeSelect">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>

        <div class="table-responsive">
            <table id="stormInfoTable" class="storm-table">
                <thead>
                    <tr>
                        <th>Name of Storm</th>
                        <th>Date of Landfall</th>
                        <th>Maximum Windspeed Achieved</th>
                    </tr>
                </thead>
                <tbody id="stormInfoTableBody">
                    @foreach (var storm in storms)
                    {
                        <tr>
                            <td>@storm.StormName</td>
                            <td>@storm.DateOfLandfall.ToString("yyyy-MM-dd")</td>
                            <td>@storm.MaxWind</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="stormPagination" class="storm-pagination"></div>
    </div>
</div>

<script id="initialStormData" type="application/json">@Html.Raw(JsonSerializer.Serialize(storms))</script>